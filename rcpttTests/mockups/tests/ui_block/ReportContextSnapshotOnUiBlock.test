------=_.content-0a7243a0-75d3-3d5f-9791-539de0e5b7ac
Content-Type: text/ecl
Entry-Name: .content

set-q7-option -key jobTreatAsSleepingTimeout -value 500

get-view "Test Explorer" | get-tree | select "Project/hangui" | get-menu -path "Run As/.*Test Cases" | click
wait 11000
waitForTaskToComplete
take-screenshot
get-view "Execution View" | get-editbox -after [get-label "Message:"] | get-property text 
    | equals "Execution .*timed out after .* seconds[\\s\\S]*" | verify-true

set-q7-option -key "context.runnable.timeout" -value 1000
get-view "Test Explorer" | get-tree | select "Project/TestWithABrokenContext" | get-menu -path "Run As/1 Test Cases" 
    | click
wait 5000
waitForTaskToComplete
   
get-view "Execution View" | get-editbox -after [get-label "Message:"] | get-property text 
    | equals  "Failed to apply context Close modal dialogs[\\s\\S]*" | verify-true
get-view "Execution View" | get-button "Details..." | click
with [get-window "Execution details"] {
	get-tab-folder | get-tab-item Description | click
	get-editbox | get-property text | contains "ECL session execute: get-advanced-info" | verify-true
	get-button "OK" | click
}
get-view "Execution View" | get-button Report | click
with [get-window -class WizardDialog] {
    with [get-editbox -after [get-label "Name:"]] {
        set-text report
    }
    get-button "Generate to workspace" | click
    with [get-editbox -after [get-label "Location:"]] {
        set-text "/Project"
    }
    get-button Finish | click
}

read-file "workspace:/Project/report.html" |  contains "ECL session execute: get-advanced-info" | verify-true
------=_.content-0a7243a0-75d3-3d5f-9791-539de0e5b7ac--
